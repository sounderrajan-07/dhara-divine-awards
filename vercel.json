{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://dhara-devineawards.vercel.app/api/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "https://dhara-devineawards.vercel.app/:path*"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://dhara-devineawards.vercel.app/_next/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
